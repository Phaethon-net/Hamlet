<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for Hamlet.

  - Static assets (.css, .js, .mjs, favicon, fonts) are cached for one year
    as immutable. Combined with the ?v=<filemtime> query string emitted by
    header.php, this means: a fresh push gives every asset a new URL,
    which is a cache miss everywhere (browser, corporate proxy, CDN);
    once fetched it never has to be re-validated.

  - The HTML page itself (index.php) is left to PHP, which sends
    Cache-Control: no-cache, no-store, must-revalidate from the top of
    index.php. export.php sets its own Content-Disposition header.

  Apache users: this file is ignored. See .htaccess instead.
-->
<configuration>
  <system.webServer>

    <staticContent>
      <!-- Make sure .mjs is served with the correct MIME type for ES
           module loading; some IIS installs ship without it. -->
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />

      <!-- 1 year, public, immutable. Applies to every static file IIS
           serves directly out of this folder (CSS, JS, ico, fonts, etc.). -->
      <clientCache cacheControlMode="UseMaxAge"
                   cacheControlMaxAge="365.00:00:00"
                   cacheControlCustom="public, immutable" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy"        value="same-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Block direct download of config / docs / dotfiles, and explicitly
         allow the extensions Hamlet actually serves. The explicit allows
         exist because some IIS sites have allowUnlisted="false" inherited
         from a parent site/app, which would otherwise 404 the .mjs PDF.js
         worker even though the file is on disk and the MIME map is set. -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".claude" />
          <add segment=".git" />
          <add segment="lib" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".ini" allowed="false" />
          <add fileExtension=".md"  allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <remove fileExtension=".mjs" />
          <add fileExtension=".mjs" allowed="true" />
          <remove fileExtension=".pdf" />
          <add fileExtension=".pdf" allowed="true" />
          <remove fileExtension=".xml" />
          <add fileExtension=".xml" allowed="true" />
        </fileExtensions>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
